	treeSet.add(10);
	treeSet.add(40);
	treeSet.add(60);
	treeSet.add(20);
	treeSet.add(100);
	System.out.println(treeSet.ceiling(90));//print heigher value to given value if value already presentr print itself
	System.out.println(treeSet.floor(90));//print lower value than this,if value already present print itself
	System.out.println(treeSet.ceiling(60));
	System.out.println(treeSet.lower(60));//strictly returns the lower than this value or already present print null
	System.out.println(treeSet.higher(110));//strictly returns the higher than this value or already present print null
	System.out.println(treeSet.subSet(10, 100));//first value is inclusive and last one is exclusive and they refers to values not index
	System.out.println(treeSet.subSet(10, false,100,true));//change the inclusive,exclusive by interchanging true,false
	System.out.println(treeSet.headSet(40));//prints the all the values above to it the value given is exclusive
	System.out.println(treeSet.tailSet(40));//prints the all the value below to it and value is also inclusive
	System.out.println(treeSet.pollFirst());//prints the smaller value NOTE:not index
	System.out.println(treeSet.pollLast());//prints the larger value  NOTE:not index
	
	
	
